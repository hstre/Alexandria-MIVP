    {
      "id": "PATCH-CHAIN-1",
      "description": "Single ADD patch with no parent (initial patch)",
      "input": {
        "patch": {
          "patch_id": "patch_001",
          "parent_patch_id": null,
          "branch_id": "main",
          "timestamp": 1000,
          "operation": "ADD",
          "target_id": "claim_001",
          "category": "EMPIRICAL",
          "payload": {
            "content": "Initial claim",
            "assumptions": [
              "assumption_a"
            ]
